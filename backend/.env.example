# Port the Express server listens on
PORT=5000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/tasker
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tasker
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tasker

# Comma-separated list of allowed frontend origins for CORS.
# Use * during local development.
CLIENT_ORIGIN=*

# Secret used to sign JWT auth tokens. Generate a strong random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
