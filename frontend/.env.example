# Base URL of the backend API (no trailing slash, no /api suffix).
# Local dev: leave empty to use the Vite proxy (/api -> localhost:5000).
# Production (Vercel): set to your deployed backend URL, e.g.
#   https://tasker-backend.vercel.app
# The app appends "/api" itself, so requests go to <VITE_API_URL>/api/...
VITE_API_URL=
